# Server-side Gemini key used by Vercel API routes.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# Supabase project URL and service role key (server only).
SUPABASE_URL="https://your-project-ref.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Environment label stored with rows (ex: local, production).
APP_ENV="local"

# Admin dashboard passcode for /admin tools.
ADMIN_DASHBOARD_PASSCODE="set-a-strong-passcode"
